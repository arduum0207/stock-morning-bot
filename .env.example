# ──────────────────────────────────────────────────────────────
# 로컬 테스트용 .env 예시. 이 파일을 `.env` 로 복사해서 값을 채우세요.
# (클라우드 예약 루틴에서는 이 값들을 Cloud Environment 의 Environment variables 패널에 넣습니다 — .env 파일 아님)
# .env 와 실제 키는 절대 커밋하지 마세요 (.gitignore 에 포함됨).
# ──────────────────────────────────────────────────────────────

# 텔레그램 (필수) — BotFather 로 봇 생성 후 토큰, 본인 chat_id
TELEGRAM_BOT_TOKEN=123456789:AAExample-bot-token
TELEGRAM_CHAT_ID=123456789

# 국내(KR) 뉴스 — 네이버 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 국내(KR) 공시 — DART OpenAPI (https://opendart.fss.or.kr)
DART_API_KEY=

# 미국(US) 실적 — Financial Modeling Prep (https://financialmodelingprep.com) — 무료 티어 가능
FMP_API_KEY=

# SEC EDGAR User-Agent (권장) — "이름 이메일" 형태. 미설정 시 기본값 사용.
COLLECT_USER_AGENT=your-name your-email@example.com
